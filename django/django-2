    {
      "filename": "views.py",
      "content": "from django.http import JsonResponse\n\n# BUG: this reads request.POST, which is only populated for\n# form-encoded bodies. JSON bodies never show up here.\ndef submit_feedback(request):\n    if request.method != 'POST':\n        return JsonResponse({'error': 'Method not allowed'}, status=405)\n\n    name = request.POST.get('name')\n    message = request.POST.get('message')\n\n    if not name or not message:\n        return JsonResponse({'error': 'name and message are required'}, status=400)\n\n    return JsonResponse({\n        'status': 'received',\n        'name': name,\n        'message': message\n    }, status=201)\n"
